@vals;	// массив значений (одномерный)
@rex;	// выражение фильтра (regexp)
@case;	// учитывать регистр
@neg;	// инвертировать результат
@r:=""

@n:=valcount(@vals)
if @n = 0 then goto end

@i:=1
while @i <= @n do [
	@ok:=$rexMatch(@vals (@i), @rex, @case)
	if (not (@neg) & @ok) | (@neg & not (@ok)) then
		@r(-1) :=@vals(@i)
	@i:=@i+1	
]

@ret:=@r

end:
