@vals;
@exclude;
if not (@exclude) then @exclude:=""
@i:=1
@a:=@vals
while @i <= valcount(@a)-1 do [
	@j:=@i+1
	while @j <= valcount(@a) do [
		@t:=compstringex(upper(@a(@i)), upper(@a(@j)), @exclude)
		if @t = 1 then [
			@a(@i) :=@a(@j)
		]	
		if @t # 3 then
			@a:=deleteval(@a,@j)
		else @j:=@j+1
	]	
	@i:=@i+1
]	

@ret:=@a
